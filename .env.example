# ================================
# Supabase
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ================================
# Stripe
# ================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ================================
# FedaPay (Paiement billets)
# ================================
FEDAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxx
FEDAPAY_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxx
FEDAPAY_WEBHOOK_SECRET=wh_live_xxxxxxxxxxxxxxxxx

# ================================
# App
# ================================
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
CRON_SECRET=change_me_to_a_long_random_secret

# ================================
# Mapbox (localisation, géocodage, cartes)
# ================================
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxx
MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxx
# Optionnel: pays prioritaires pour la recherche d'adresse (ISO alpha-2, séparés par virgules)
MAPBOX_COUNTRY_CODES=bj,ci,tg,sn

# ================================
# Twilio (SMS)
# ================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+33xxxxxxxxx
