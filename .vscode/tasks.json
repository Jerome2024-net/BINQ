{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Next.js",
			"type": "shell",
			"command": "$env:NODE_OPTIONS='--max-old-space-size=8192'; npx next build",
			"group": "build"
		},
		{
			"label": "next-build",
			"type": "shell",
			"command": "set NODE_OPTIONS=--max-old-space-size=8192 && npx next build",
			"group": "build"
		},
		{
			"label": "git-push",
			"type": "shell",
			"command": "git add -A && git commit -m \"fix: remove double getUserMedia, add photo QR scanner fallback for all phones\" && git push origin main",
			"group": "none"
		},
		{
			"label": "build-binq",
			"type": "shell",
			"command": "$env:NODE_OPTIONS='--max-old-space-size=8192'; npx next build",
			"group": "build"
		},
		{
			"label": "build-binq",
			"type": "shell",
			"command": "$env:NODE_OPTIONS='--max-old-space-size=8192'; npx next build",
			"group": "build"
		}
	]
